# Dependencies
node_modules/

# Build outputs
dist/
build/
.svelte-kit/

# D6 — packages/vault-action/dist/ is the one exception: it is the literal artifact GitHub
# Actions executes for every `uses: project-vault/vault-action@v1` consumer (the Actions runtime
# never runs an install step), so it must be committed. Kept fresh by the CI check in
# scripts/check-vault-action-dist-fresh.ts — do not "clean this up" by re-ignoring it.
!packages/vault-action/dist/
!packages/vault-action/dist/**

# Coverage
coverage/
.nyc_output/

# Stryker
.stryker-tmp/
reports/

# Environment files
.env*
!.env.example
!apps/web/e2e/.env.test.example

# Playwright (Story 10-1)
apps/web/e2e/test-results/

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Turbo
.turbo/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Local assistant artifacts
.claude/
prompts.md

# TypeScript
*.tsbuildinfo

# Misc
*.tmp

# Vault key material (envelope/file mode halves) — never commit secrets
dev-secrets/*
!dev-secrets/.gitkeep

# Story 11-1 — raw, unprocessed brand source uploads (1024x1024 originals, ~1.4-1.5MB each).
# The derived, production-ready assets they were cropped/resized into live in
# apps/web/static/ (logo.png, icon.png, favicon.png, apple-touch-icon.png) and ARE committed —
# the app references them directly. These originals are only needed if the assets are ever
# regenerated from scratch, not to build or run the app, so they stay out of version control.
design/brand-source/
/project-vault-logo.png
/project-vault-icon.png
