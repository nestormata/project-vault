# Dependencies
node_modules/

# Build outputs
dist/
build/
.svelte-kit/

# D6 — packages/vault-action/dist/ is the one exception: it is the literal artifact GitHub
# Actions executes for every `uses: project-vault/vault-action@v1` consumer (the Actions runtime
# never runs an install step), so it must be committed. Kept fresh by the CI check in
# scripts/check-vault-action-dist-fresh.ts — do not "clean this up" by re-ignoring it.
!packages/vault-action/dist/
!packages/vault-action/dist/**

# Coverage
coverage/
.nyc_output/

# Stryker
.stryker-tmp/
reports/

# Environment files
.env*
!.env.example
!apps/web/e2e/.env.test.example

# Playwright (Story 10-1)
apps/web/e2e/test-results/

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Turbo
.turbo/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Local assistant artifacts
.claude/
prompts.md

# TypeScript
*.tsbuildinfo

# Misc
*.tmp

# Vault key material (envelope/file mode halves) — never commit secrets
dev-secrets/*
!dev-secrets/.gitkeep
