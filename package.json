{
  "name": "project-vault",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "generate-spec": "turbo generate-spec",
    "jscpd": "jscpd apps packages scripts",
    "db:migrate": "pnpm --filter @project-vault/db db:migrate",
    "check-rls": "tsx scripts/check-rls-coverage.ts",
    "check-audit-actor-token-coverage": "tsx scripts/check-audit-actor-token-coverage.ts",
    "check-search-index": "tsx scripts/check-search-index.ts",
    "check-alert-pending-epic3": "tsx scripts/check-alert-pending-epic3.ts",
    "check-vault-action-dist": "tsx scripts/check-vault-action-dist-fresh.ts",
    "check-migration-compatibility": "tsx scripts/migration-compatibility-check.ts",
    "check-story-status-sync": "tsx scripts/check-story-status-sync.ts",
    "check-psc-tbd-tracking": "tsx scripts/check-psc-tbd-tracking.ts",
    "docker:smoke": "bash scripts/docker-smoke.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "audit-ci": "^7.1.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.12",
    "lint-staged": "^17.0.8",
    "postgres": "^3.4.5",
    "prettier": "3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "tsx": "4.23.0",
    "turbo": "latest",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
