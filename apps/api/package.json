{
  "name": "@project-vault/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "generate-spec": "tsx src/scripts/generate-spec.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@fastify/cookie": "^11.1.1",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@project-vault/crypto": "workspace:*",
    "@project-vault/db": "workspace:*",
    "@project-vault/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.0",
    "fast-jwt": "^6.2.4",
    "fastify": "5.10.0",
    "fastify-plugin": "^6.0.0",
    "nodemailer": "^9.0.3",
    "otpauth": "^9.5.1",
    "pg-boss": "12.26.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "undici": "^8.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@project-vault/agent": "workspace:*",
    "@project-vault/eslint-config": "workspace:*",
    "@project-vault/tsconfig": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/form-data": "^2.5.2",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "form-data": "^4.0.6",
    "tsx": "4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
