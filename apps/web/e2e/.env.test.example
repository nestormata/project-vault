# Template for apps/web/e2e/.env.test (git-ignored — matches root .env.example's pattern).
# None of these need to be set for a normal local `make e2e` run against the default
# docker-compose ports; they exist as documented override points (e.g. a worktree that bumped
# ports via `make fix-ports`, or a CI job pointing at a non-default host).

# Overrides playwright.config.ts's baseURL (default: http://localhost:${WEB_HOST_PORT:-5173}).
# E2E_BASE_URL=http://localhost:5173

# Overrides global-setup.ts's API readiness/vault-init target
# (default: http://localhost:${API_HOST_PORT:-3000}).
# E2E_API_BASE_URL=http://localhost:3000

# Overrides fixtures/db.ts's DB connection strings used for schema reset + invitation-token
# lookup (defaults derived from DB_HOST_PORT, matching this repo's superuser/vault_app roles).
# E2E_SUPERUSER_DATABASE_URL=postgresql://postgres:password@localhost:5432/project_vault
# E2E_APP_DATABASE_URL=postgresql://vault_app:dev-only-change-in-prod@localhost:5432/project_vault
