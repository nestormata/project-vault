{
  "name": "@project-vault/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "files": [
    "build"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run --coverage",
