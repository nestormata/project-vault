{
  "extends": "@project-vault/tsconfig/svelte.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "@project-vault/shared": ["../../packages/shared/src/index.ts"]
    },
    "rootDirs": [".", ".svelte-kit/types"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", ".svelte-kit/ambient.d.ts", ".svelte-kit/types/**/*.d.ts"],
  "exclude": ["node_modules", "src/**/*.test.ts", "src/**/*.spec.ts"]
}
