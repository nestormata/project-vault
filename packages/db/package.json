{
  "name": "@project-vault/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-helpers": {
      "types": "./dist/test-helpers.d.ts",
      "default": "./dist/test-helpers.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "build": "tsc",
    "generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:test": "tsx src/seed-test.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@project-vault/eslint-config": "workspace:*",
    "@project-vault/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
