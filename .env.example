# IMPORTANT: Must use vault_app role, NOT postgres. Using postgres bypasses all RLS.
# Local dev (running outside Docker — pnpm turbo dev):
DATABASE_URL=postgresql://vault_app:change-me-in-env@localhost:5432/project_vault
# Inside Docker Compose (api container connecting to db container):
# DATABASE_URL=postgresql://vault_app:change-me-in-env@db:5432/project_vault
# Switch to the db hostname when running via docker compose
# Note: docker compose up ignores this file's DATABASE_URL for the api/web services — see docker-compose.yml
#
# PRODUCTION HARDENING (required before any non-dev deployment):
# The 'dev-only-change-in-prod' password created by 0001_rls_and_triggers.sql is a
# local-development placeholder only. Before deploying, either:
#   - Run `ALTER ROLE vault_app PASSWORD '<secure-random-password>'` immediately after migration, OR
#   - Configure pg_hba.conf to use scram-sha-256 or peer auth for vault_app and remove the
#     password from the role entirely: `ALTER ROLE vault_app NOLOGIN; ALTER ROLE vault_app LOGIN`

# POSTGRES_USER/PASSWORD/DB bootstrap the Postgres superuser for the container itself
# (not the app's connection role). The vault_app role above is created by db:migrate.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=project_vault

API_PORT=3000
WEB_PORT=5173
NODE_ENV=development

# Host-side port bindings for `docker compose up` (container-internal ports are fixed).
# Override these per checkout/worktree to run multiple stacks concurrently without
# host port collisions (e.g. DB_HOST_PORT=5433 in a worktree's .env). Or just run
# `make fix-ports` (see AGENTS.md "Docker port isolation") to auto-assign free ones.
DB_HOST_PORT=5432
API_HOST_PORT=3000
WEB_HOST_PORT=5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Structured operational logging & metrics (Story 1.10)
# LOG_LEVEL defaults to silent when NODE_ENV=test. Keep debug/trace out of production.
METRICS_BIND_HOST=127.0.0.1
# Set METRICS_BIND_HOST=0.0.0.0 only when an external Prometheus scraper is intended.
LOG_LEVEL=info
SERVICE_NAME=api

# User Registration & Password Authentication (Story 1.6)
# Production: generate distinct 32+ byte secrets, for example: openssl rand -hex 32
SESSION_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
REFRESH_TOKEN_HMAC_SECRET=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
JWT_ACCESS_TTL_SECONDS=300
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ACTIVITY_DEBOUNCE_SECONDS=60
MAX_SESSIONS_PER_USER=0
JWT_MAX_CLOCK_SKEW_SECONDS=30
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_GRACE_WINDOW_SECONDS=30

# TOTP MFA Enrollment & Recovery Codes (Story 1.8)
MFA_TOTP_ISSUER=Project Vault
MFA_TOTP_PERIOD_SECONDS=30
MFA_TOTP_DIGITS=6
MFA_TOTP_WINDOW=1
MFA_RECOVERY_CODE_COUNT=10
MFA_RECOVERY_CODE_BCRYPT_COST=12
TOTP_USED_CODES_TTL_MINUTES=90
# Production: generate a dedicated 32+ byte secret, distinct from REFRESH_TOKEN_HMAC_SECRET.
# Local/test may leave empty to fall back to REFRESH_TOKEN_HMAC_SECRET.
TOTP_REPLAY_HMAC_SECRET=

# MFA Role Enforcement & Failed Auth Detection (Story 1.9)
MFA_PRIVILEGED_ROLE_GRACE_DAYS=7
FAILED_AUTH_THRESHOLD_COUNT=10
FAILED_AUTH_THRESHOLD_WINDOW_SECONDS=300
FAILED_AUTH_RETENTION_HOURS=24
FAILED_AUTH_RECORD_ENABLED=true

# HTTP Endpoint Monitoring & Anomalous Access Detection (Story 6.2)
MAX_SERVICE_ENDPOINTS_PER_PROJECT=25
HEALTH_CHECK_MAX_CONCURRENCY=20
ANOMALOUS_ACCESS_THRESHOLD_COUNT=5
ANOMALOUS_ACCESS_WINDOW_SECONDS=3600

# MFA Login Verification (Story 1.12)
MFA_PENDING_SESSION_TTL_SECONDS=300
MFA_LOGIN_MAX_ATTEMPTS=5
# Required in production; must differ from SESSION_SECRET / REFRESH_TOKEN_HMAC_SECRET / TOTP_REPLAY_HMAC_SECRET.
MFA_PENDING_SESSION_HMAC_SECRET=

# Team Invitations & Role Assignment (Story 4.1)
# Required in production; must differ from every other HMAC secret above.
# Local/test may leave empty to fall back to a dedicated dev-only secret.
INVITATION_TOKEN_HMAC_SECRET=
# Base URL of the web app, used to build invitation accept links.
WEB_BASE_URL=http://localhost:5173

# Account Deactivation & Recovery (Story 4.3)
# Required in production; must differ from every other HMAC secret above.
# Local/test may leave empty to fall back to a dedicated dev-only secret.
RECOVERY_TOKEN_HMAC_SECRET=

# Machine User API Keys (Story 7.1)
# Required in production; must differ from every other HMAC secret above.
# Local/test may leave empty to fall back to a dedicated dev-only secret.
API_KEY_HMAC_SECRET=

ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
# Dev/test dummy hash used to equalize unknown-email login timing.
AUTH_DUMMY_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$c/PLdA7Wvhkg8hPqLu5AlQ$7zS8GhNtQTJsiMmJLErN9kM19VoNBM3PHV3OhidvHtY
AUTH_REGISTRATION_ENABLED=true
# Use true in production/staging HTTPS. Local HTTP dev uses false.
COOKIE_SECURE=false
# Set TRUST_PROXY=true only behind a trusted reverse proxy such as Traefik/nginx.
TRUST_PROXY=false
TRUST_PROXY_HOPS=1

# Credential retention purge is irreversible (Story 2.2 AC-8/AC-11B). Defaults to dry-run
# (log-only) in production; uncomment false only after verifying dry-run output and backups.
CREDENTIAL_RETENTION_DRY_RUN=true

# Vault Initialization & Master Key Management (Story 1.5)
# Directory for envelope/file key halves — mounted read-only in production (Docker secrets /
# Kubernetes secretKeyRef convention). Defaults to /run/secrets if unset.
VAULT_KEY_DIR=/run/secrets
# Envelope mode only (16 bytes as 32 hex chars). Generate: openssl rand -hex 16
# Leave empty in development (file-key mode is used by default).
VAULT_ENVELOPE_KEY_HALF=
# First-init protection — generate: openssl rand -base64 32. Required in production
# unless VAULT_ALLOW_REMOTE_INIT=true (dev-only, NEVER set true in production).
# Leave empty in development when VAULT_ALLOW_REMOTE_INIT=true.
VAULT_BOOTSTRAP_TOKEN=
VAULT_ALLOW_REMOTE_INIT=false

# Email notifications (optional; omit to disable) — Story 3.1
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=notifications@example.com

# Slack notifications (optional; omit to disable) — Story 3.1
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-path

# Daily digest email hour (UTC, 0–23) — Story 3.2
NOTIFICATION_DIGEST_HOUR=8

# Inbox entry retention in days before automatic purge — Story 3.3
INBOX_RETENTION_DAYS=90

# For production:
