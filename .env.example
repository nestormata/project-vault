# IMPORTANT: Must use vault_app role, NOT postgres. Using postgres bypasses all RLS.
# Local dev (running outside Docker — pnpm turbo dev):
DATABASE_URL=postgresql://vault_app:change-me-in-env@localhost:5432/project_vault
# Inside Docker Compose (api container connecting to db container):
# DATABASE_URL=postgresql://vault_app:change-me-in-env@db:5432/project_vault
# Switch to the db hostname when running via docker compose
# Note: docker compose up ignores this file's DATABASE_URL for the api/web services — see docker-compose.yml
#
# PRODUCTION HARDENING (required before any non-dev deployment):
# The 'dev-only-change-in-prod' password created by 0001_rls_and_triggers.sql is a
# local-development placeholder only. Before deploying, either:
#   - Run `ALTER ROLE vault_app PASSWORD '<secure-random-password>'` immediately after migration, OR
#   - Configure pg_hba.conf to use scram-sha-256 or peer auth for vault_app and remove the
#     password from the role entirely: `ALTER ROLE vault_app NOLOGIN; ALTER ROLE vault_app LOGIN`

# POSTGRES_USER/PASSWORD/DB bootstrap the Postgres superuser for the container itself
# (not the app's connection role). The vault_app role above is created by db:migrate.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=project_vault

API_PORT=3000
WEB_PORT=5173
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173
METRICS_BIND_HOST=127.0.0.1
LOG_LEVEL=info

# Vault Initialization & Master Key Management (Story 1.5)
# Directory for envelope/file key halves — mounted read-only in production (Docker secrets /
# Kubernetes secretKeyRef convention). Defaults to /run/secrets if unset.
VAULT_KEY_DIR=/run/secrets
# Envelope mode only (16 bytes as 32 hex chars). Generate: openssl rand -hex 16
# Leave empty in development (file-key mode is used by default).
VAULT_ENVELOPE_KEY_HALF=
# First-init protection — generate: openssl rand -base64 32. Required in production
# unless VAULT_ALLOW_REMOTE_INIT=true (dev-only, NEVER set true in production).
# Leave empty in development when VAULT_ALLOW_REMOTE_INIT=true.
VAULT_BOOTSTRAP_TOKEN=
VAULT_ALLOW_REMOTE_INIT=false

# For production:
# SLACK_WEBHOOK_URL=<webhook for nightly failure alerts>
