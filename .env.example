# IMPORTANT: Must use vault_app role, NOT postgres. Using postgres bypasses all RLS.
# Local dev (running outside Docker — pnpm turbo dev):
DATABASE_URL=postgresql://vault_app:change-me-in-env@localhost:5432/project_vault
# Inside Docker Compose (api container connecting to db container):
# DATABASE_URL=postgresql://vault_app:change-me-in-env@db:5432/project_vault
# Switch to the db hostname when running via docker compose
# Note: docker compose up ignores this file's DATABASE_URL for the api/web services — see docker-compose.yml
#
# PRODUCTION HARDENING (required before any non-dev deployment):
# The 'dev-only-change-in-prod' password created by 0001_rls_and_triggers.sql is a
# local-development placeholder only. Before deploying, either:
#   - Run `ALTER ROLE vault_app PASSWORD '<secure-random-password>'` immediately after migration, OR
#   - Configure pg_hba.conf to use scram-sha-256 or peer auth for vault_app and remove the
#     password from the role entirely: `ALTER ROLE vault_app NOLOGIN; ALTER ROLE vault_app LOGIN`

# POSTGRES_USER/PASSWORD/DB bootstrap the Postgres superuser for the container itself
# (not the app's connection role). The vault_app role above is created by db:migrate.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=project_vault

# Used by getAdminDb() (apps/api/src/lib/db.ts) for legitimate cross-org reads that predate RLS
# org context — e.g. registration's global data-erasure-request lookup, which runs before the
# new org even exists. Superuser, same as DATABASE_URL's production-hardening note above. Also
# read by `make test` (see Makefile DB_URL_SUPERUSER). Not part of the Zod-validated env schema
# (apps/api/src/config/env.ts) — read directly, same as BACKUP_DATABASE_URL's superuser reuse.
ADMIN_DATABASE_URL=postgresql://postgres:password@localhost:5432/project_vault

API_PORT=3000
WEB_PORT=5173
NODE_ENV=development

# Host-side port bindings for `docker compose up` (container-internal ports are fixed).
# Override these per checkout/worktree to run multiple stacks concurrently without
# host port collisions (e.g. DB_HOST_PORT=5433 in a worktree's .env). Or just run
# `make fix-ports` (see AGENTS.md "Docker port isolation") to auto-assign free ones.
DB_HOST_PORT=5432
API_HOST_PORT=3000
WEB_HOST_PORT=5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Structured operational logging & metrics (Story 1.10)
# LOG_LEVEL defaults to silent when NODE_ENV=test. Keep debug/trace out of production.
METRICS_BIND_HOST=127.0.0.1
# Set METRICS_BIND_HOST=0.0.0.0 only when an external Prometheus scraper is intended.
LOG_LEVEL=info
SERVICE_NAME=api

# User Registration & Password Authentication (Story 1.6)
# Production: generate distinct 32+ byte secrets, for example: openssl rand -hex 32
SESSION_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
REFRESH_TOKEN_HMAC_SECRET=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
JWT_ACCESS_TTL_SECONDS=300
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ACTIVITY_DEBOUNCE_SECONDS=60
MAX_SESSIONS_PER_USER=0
JWT_MAX_CLOCK_SKEW_SECONDS=30
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_GRACE_WINDOW_SECONDS=30

# TOTP MFA Enrollment & Recovery Codes (Story 1.8)
MFA_TOTP_ISSUER=Project Vault
MFA_TOTP_PERIOD_SECONDS=30
MFA_TOTP_DIGITS=6
MFA_TOTP_WINDOW=1
MFA_RECOVERY_CODE_COUNT=10
MFA_RECOVERY_CODE_BCRYPT_COST=12
TOTP_USED_CODES_TTL_MINUTES=90
# Production: generate a dedicated 32+ byte secret, distinct from REFRESH_TOKEN_HMAC_SECRET.
# Local/test may leave empty to fall back to REFRESH_TOKEN_HMAC_SECRET.
TOTP_REPLAY_HMAC_SECRET=

# MFA Role Enforcement & Failed Auth Detection (Story 1.9)
MFA_PRIVILEGED_ROLE_GRACE_DAYS=7
FAILED_AUTH_THRESHOLD_COUNT=10
FAILED_AUTH_THRESHOLD_WINDOW_SECONDS=300
FAILED_AUTH_RETENTION_HOURS=24
FAILED_AUTH_RECORD_ENABLED=true

# HTTP Endpoint Monitoring & Anomalous Access Detection (Story 6.2)
MAX_SERVICE_ENDPOINTS_PER_PROJECT=25
HEALTH_CHECK_MAX_CONCURRENCY=20
ANOMALOUS_ACCESS_THRESHOLD_COUNT=5
ANOMALOUS_ACCESS_WINDOW_SECONDS=3600

# Cross-Project Health Dashboard & Public Status Page (Story 6.3)
# Signs public status-page opaque tokens. Required in production; must differ from every other
# HMAC secret above. Local/test may leave empty to fall back to a dedicated dev-only secret.
STATUS_PAGE_TOKEN_HMAC_SECRET=

# MFA Login Verification (Story 1.12)
MFA_PENDING_SESSION_TTL_SECONDS=300
MFA_LOGIN_MAX_ATTEMPTS=5
# Required in production; must differ from SESSION_SECRET / REFRESH_TOKEN_HMAC_SECRET / TOTP_REPLAY_HMAC_SECRET.
MFA_PENDING_SESSION_HMAC_SECRET=

# Data Subject Erasure Request Handling (Story 8.4)
# Keys data_erasure_requests.original_email_hash (D6) — never reuse the audit-log HMAC key or any
# other auth-token HMAC secret above. Required in production; local/test may leave empty to fall
# back to a dedicated dev-only secret.
ERASURE_EMAIL_HASH_SECRET=

# Team Invitations & Role Assignment (Story 4.1)
# Required in production; must differ from every other HMAC secret above.
# Local/test may leave empty to fall back to a dedicated dev-only secret.
INVITATION_TOKEN_HMAC_SECRET=
# Base URL of the web app, used to build invitation accept links.
WEB_BASE_URL=http://localhost:5173

# Account Deactivation & Recovery (Story 4.3)
# Required in production; must differ from every other HMAC secret above.
# Local/test may leave empty to fall back to a dedicated dev-only secret.
RECOVERY_TOKEN_HMAC_SECRET=

# Machine User API Keys (Story 7.1)
# Required in production; must differ from every other HMAC secret above.
# Local/test may leave empty to fall back to a dedicated dev-only secret.
API_KEY_HMAC_SECRET=

# Machine Token Exchange JWT (Story 7.2, D3)
# Required in production; must differ from every other HMAC secret above. Signs a second,
# independent HS256 JWT context distinct from the human-session SESSION_SECRET.
# Local/test may leave empty to fall back to a dedicated dev-only secret.
MACHINE_JWT_SECRET=
MACHINE_JWT_TTL_SECONDS=3600

ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
# Dev/test dummy hash used to equalize unknown-email login timing.
AUTH_DUMMY_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$c/PLdA7Wvhkg8hPqLu5AlQ$7zS8GhNtQTJsiMmJLErN9kM19VoNBM3PHV3OhidvHtY
AUTH_REGISTRATION_ENABLED=true
# Use true in production/staging HTTPS. Local HTTP dev uses false.
COOKIE_SECURE=false
# Set TRUST_PROXY=true only behind a trusted reverse proxy such as Traefik/nginx.
TRUST_PROXY=false
TRUST_PROXY_HOPS=1

# Story 9.3 D5: exposes GET /api/v1/openapi.json and GET /api/v1/docs (Swagger UI) — a fully
# browsable map of every authenticated route and its exact request/response schema. Defaults to
# false (fail-closed) even outside this flag: docs are also auto-enabled when NODE_ENV is
# development or test, so most local/dev/CI usage never needs to set this at all. Only set true
# in production if you intend to expose the docs deliberately (e.g. behind your own reverse-proxy
# auth) — see docs/runbook.md § Upgrades for the operational trade-off.
ENABLE_API_DOCS=false

# Credential retention purge is irreversible (Story 2.2 AC-8/AC-11B). Defaults to dry-run
# (log-only) in production; uncomment false only after verifying dry-run output and backups.
CREDENTIAL_RETENTION_DRY_RUN=true

# Vault Initialization & Master Key Management (Story 1.5)
# Directory for envelope/file key halves — mounted read-only in production (Docker secrets /
# Kubernetes secretKeyRef convention). Defaults to /run/secrets if unset.
VAULT_KEY_DIR=/run/secrets
# Envelope mode only (16 bytes as 32 hex chars). Generate: openssl rand -hex 16
# Leave empty in development (file-key mode is used by default).
VAULT_ENVELOPE_KEY_HALF=
# First-init protection — generate: openssl rand -base64 32. Required in production
# unless VAULT_ALLOW_REMOTE_INIT=true (dev-only, NEVER set true in production).
# Leave empty in development when VAULT_ALLOW_REMOTE_INIT=true.
VAULT_BOOTSTRAP_TOKEN=
VAULT_ALLOW_REMOTE_INIT=false

# Email notifications (optional; omit to disable) — Story 3.1
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=notifications@example.com

# Slack notifications (optional; omit to disable) — Story 3.1
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-path

# Daily digest email hour (UTC, 0–23) — Story 3.2
NOTIFICATION_DIGEST_HOUR=8

# Inbox entry retention in days before automatic purge — Story 3.3
INBOX_RETENTION_DAYS=90

# Rotation checklist retry cap — read fresh on every retry call (Story 5.2 AC-7/AC-E5b)
ROTATION_MAX_RETRIES=3

# Break-glass emergency-rotation overlap window in minutes, and the stale-rotation detection
# job's time threshold in minutes (Story 5.3 AC-8/AC-9/CR1/CR2)
BREAK_GLASS_OVERLAP_MINUTES=60
STALE_ROTATION_THRESHOLD_MINUTES=60

# Break-glass double-submit idempotency window in seconds (Story 5.5 AC-4)
BREAK_GLASS_IDEMPOTENCY_WINDOW_SECONDS=10

# Encrypted Backup & Restore (Story 9.1). Backup is opt-in — leave BACKUP_STORAGE_PATH,
# BACKUP_S3_BUCKET, and BACKUP_DATABASE_URL all empty to disable it entirely (AC-15).
# Configure exactly one destination (BACKUP_STORAGE_PATH XOR BACKUP_S3_BUCKET) plus
# BACKUP_DATABASE_URL — a connection that bypasses RLS (D4). For v1, reuse the superuser
# credential above; operators may optionally create a dedicated BYPASSRLS `vault_backup` role.
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_COUNT=7
# Story 9.6: operator-tunable, independent of the PRD's 24h RPO design target and of the
# hardcoded 24h orphan-staged-file cleanup window below — tuning one does not affect the others.
BACKUP_MAX_AGE_HOURS=25
BACKUP_STORAGE_PATH=
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=
BACKUP_DATABASE_URL=
# Story 9.6 D3.1: local staging directory for the S3 destination only — the encrypted backup is
# written here atomically BEFORE upload, and retained (not deleted) if the upload ultimately fails
# after retries, so a subsequent manual retry doesn't require re-running the entire dump+encrypt
# pipeline. Ignored entirely for the BACKUP_STORAGE_PATH (filesystem) destination.
# Unset default: os.tmpdir() + '/vault-backup-staging' — this does NOT survive a container
# restart (ephemeral /tmp). If you want a failed upload's staged file to survive a restart (so the
# 24h orphan-cleanup window, hardcoded and not itself configurable, is meaningful across restarts,
# not just within one process lifetime), set this to a path on a mounted, persistent volume —
# mirror this file's BACKUP_STORAGE_PATH volume-mount precedent in docker-compose.yml.
# Operator convention: a staged file older than 24h is swept automatically. To protect a file
# you're still manually investigating from that sweep, rename it to break the exact `.staged`
# suffix match (e.g. `....vault.staged` -> `....vault.staged.hold`) — the sweep only ever touches
# files matching `*.staged` literally.
BACKUP_S3_STAGING_PATH=
# Story 9.6 D3.9/AC-16b: optional monitoring threshold (bytes) for total staging-directory usage
# across all `.staged` files — raises a backup.staging_disk_pressure admin_alerts row if exceeded
# (e.g. during a prolonged S3 outage). Unset disables this check entirely; it is a monitoring
# addition only and never blocks a backup attempt from proceeding.
BACKUP_S3_STAGING_MAX_BYTES=

# Story 9.2 D5/D8: system settings, multi-org & resource monitoring.
AUDIT_LOG_STORAGE_LIMIT_GB=50
KEY_ROTATION_MAX_AGE_DAYS=365

# Story 9.4 AC-17/AC-18: platform operator audit log retention and storage monitoring.
PLATFORM_AUDIT_RETENTION_DAYS=365
PLATFORM_AUDIT_STORAGE_LIMIT_GB=5

# SonarCloud Web API access (make sonar-issues / ./scripts/sonar-issues.sh) — see
# docs/sonarqube.md. This project uses SonarCloud's Automatic Analysis (Autoscan), configured
# via the committed .sonarcloud.properties — there is no local/CI scan to run. These vars are
# only for *reading* results (issues, hotspots, quality gate status) from the CLI.
# SONAR_TOKEN is a secret (SonarCloud > My Account > Security > Generate Token); never commit
# a real value. SONAR_ORGANIZATION/SONAR_PROJECT_KEY are the org/project keys shown in
# SonarCloud — not secret, but kept out of committed files anyway for consistency.
SONAR_TOKEN=
SONAR_ORGANIZATION=
SONAR_PROJECT_KEY=
# Only override if self-hosting SonarQube instead of SonarCloud.
SONAR_HOST_URL=https://sonarcloud.io

# For production:
