# IMPORTANT: Must use vault_app role, NOT postgres. Using postgres bypasses all RLS.
# Local dev (running outside Docker — pnpm turbo dev):
DATABASE_URL=postgresql://vault_app:change-me-in-env@localhost:5432/project_vault
# Inside Docker Compose (api container connecting to db container):
# DATABASE_URL=postgresql://vault_app:change-me-in-env@db:5432/project_vault
# Switch to the db hostname when running via docker compose
# Note: docker compose up ignores this file's DATABASE_URL for the api/web services — see docker-compose.yml

# POSTGRES_USER/PASSWORD/DB bootstrap the Postgres superuser for the container itself
# (not the app's connection role). The vault_app role above is created by db:migrate.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=project_vault

API_PORT=3000
WEB_PORT=5173
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173
METRICS_BIND_HOST=127.0.0.1
LOG_LEVEL=info

# For production:
# SLACK_WEBHOOK_URL=<webhook for nightly failure alerts>
