{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "generate-spec": {
      "dependsOn": ["^build"],
      "outputs": ["../../packages/shared/openapi.json"]
    },
    "typecheck": {
      "dependsOn": ["generate-spec"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
