{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "API_PORT",
    "CORS_ALLOWED_ORIGINS",
    "DATABASE_URL",
    "LOG_LEVEL",
    "METRICS_BIND_HOST",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "generate-spec": {
      "dependsOn": ["^build"],
      "outputs": ["../../packages/shared/openapi.json"]
    },
    "typecheck": {
      "dependsOn": ["generate-spec"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
